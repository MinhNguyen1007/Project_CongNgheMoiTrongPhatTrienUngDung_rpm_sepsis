# Copy sang .env (không commit) và điền giá trị thật.

# ── AWS / LocalStack ────────────────────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# ── MLflow ──────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
MLFLOW_ARTIFACT_BUCKET=mlflow

# ── MinIO ───────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ── Postgres (app DB) ───────────────────────────────────
POSTGRES_USER=rpm_user
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=rpm
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Backend ─────────────────────────────────────────────
JWT_SECRET=change_me_generate_with_openssl_rand_32
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:5173

# ── Frontend ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws/alerts

# ── Alerting ────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME

# ── Model ───────────────────────────────────────────────
MODEL_NAME=sepsis-lgbm-prod
MODEL_STAGE=Production
ALERT_THRESHOLD=0.5
# Backend bỏ qua MODEL_STAGE khi có MODEL_URI explicit — pin version 4 đến khi promote
MODEL_URI=models:/sepsis-lgbm-prod/4

# ── Consumer → Backend wiring ───────────────────────────
BACKEND_URL=http://localhost:8000
BACKEND_PREDICT_ENABLED=true
BACKEND_PREDICT_TIMEOUT=3.0
